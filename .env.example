# ===== SERVER-SIDE (NUNCA se expone al navegador) =====
# API key de Anthropic. En Vercel: Settings → Environment Variables.
ANTHROPIC_API_KEY=sk-ant-...

# Modelo de Claude a usar (opcional, default abajo)
ANTHROPIC_MODEL=claude-sonnet-4-6

# URL del Web App de Apps Script (deploy como /exec). El servidor la usa para:
#  1) revisar si el correo ya generó su análisis gratis (candado anti-reuso)
#  2) registrar el lead en el Sheet tras una generación exitosa
# Si no defines APPS_SCRIPT_URL, el server cae a NEXT_PUBLIC_WEBHOOK_URL.
APPS_SCRIPT_URL=

# Token de Apify (solo /landing-3): análisis competitivo vía el actor
# automation-lab/facebook-ads-library. Si no se define, /landing-3 funciona igual
# pero SIN la sección de análisis competitivo (fail-soft).
APIFY_TOKEN=

# fal.ai (solo /landing-3): genera la imagen del estático desde el prompt.
FAL_KEY=
# Modelo de fal. Default: fal-ai/gpt-image-2 (id oficial del API). Opcionales:
FAL_IMAGE_MODEL=fal-ai/gpt-image-2
FAL_IMAGE_QUALITY=low      # low | medium | high  (low = rápido y barato)
FAL_IMAGE_SIZE=square_hd   # 1024x1024

# Stripe (checkout de la "campaña completa" por ~$27 USD, multimoneda según el país).
STRIPE_SECRET_KEY=sk_live_...

# ===== PUBLIC (sí se exponen al navegador, no son secretos) =====
# Misma URL del Apps Script. Puedes definir solo esta y el server la reutiliza.
NEXT_PUBLIC_WEBHOOK_URL=

# Link de tu agenda (Calendly / WhatsApp) para el botón "Agendar demo".
NEXT_PUBLIC_DEMO_URL=
